{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://157.230.254.81:8001/:path*"
    },
    {
      "source": "/public/:path*",
      "destination": "http://157.230.254.81:8001/public/:path*"
    },
    {
      "source": "/products/:path*",
      "destination": "http://157.230.254.81:8001/products/:path*"
    },
    {
      "source": "/products",
      "destination": "http://157.230.254.81:8001/products"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
